# ── Dependencies ──────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────
dist/
dist-ssr/

# ── Environment & local config ────────────────────────────
*.env
*.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# ── Claude Code harness (development tooling, not shipped) ──
CLAUDE.md
SPRINT.md
.claude/agents/
.claude/skills/
.claude/settings.local.json

# ── Large media files (too big for git) ───────────────────
# Keep source images in assets/ — only exclude videos and audio
assets/*.mp4
assets/*.mov
assets/*.webm
assets/*.mp3
assets/*.ogg
assets/*.wav
assets/*.m4a
public/videos/*.mov
public/videos/*.webm
# public/audio — bgmusic + hover SFX tracked; onclick removed intentionally
public/audio/onclick.mp3

# ── Logs ──────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS & editor junk ──────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Cache ─────────────────────────────────────────────────
.cache/
.parcel-cache/
